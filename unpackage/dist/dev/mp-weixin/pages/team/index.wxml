<view class="team-page safe-top data-v-1e67a536"><view class="page-header data-v-1e67a536"><text class="page-title data-v-1e67a536">组队</text></view><view class="page-inner data-v-1e67a536"><view class="card join-section data-v-1e67a536"><text class="section-title data-v-1e67a536">加入组队</text><view class="join-row data-v-1e67a536"><input class="join-input data-v-1e67a536" placeholder="输入8位数字组队码" maxlength="8" value="{{a}}" bindinput="{{b}}"/><view class="join-btn data-v-1e67a536" bindtap="{{c}}">查看</view></view><text class="join-hint data-v-1e67a536">输入好友的组队码，测测你是否适合加入</text></view><view wx:if="{{d}}" class="card history-section data-v-1e67a536"><text class="section-title data-v-1e67a536">已创建队伍</text><view class="team-list data-v-1e67a536"><view wx:for="{{e}}" wx:for-item="t" wx:key="i" class="team-item data-v-1e67a536"><view class="team-top data-v-1e67a536"><text class="team-rel data-v-1e67a536">{{t.a}}</text><text wx:if="{{t.b}}" class="team-dest data-v-1e67a536">{{t.c}}</text><view class="team-code-actions data-v-1e67a536"><text class="team-code-text data-v-1e67a536">{{t.d}}</text><text class="team-copy-btn data-v-1e67a536" catchtap="{{t.e}}">复制</text></view></view><view wx:if="{{t.f}}" class="team-members data-v-1e67a536"><view class="tm-label data-v-1e67a536"><text class="tm-label-text data-v-1e67a536">已加入：</text><text class="tm-count data-v-1e67a536">{{t.g}}人合适</text></view><view class="tm-avatars data-v-1e67a536"><view wx:for="{{t.h}}" wx:for-item="m" wx:key="e" class="tm-member data-v-1e67a536"><image class="tm-avatar data-v-1e67a536" src="{{m.a}}" mode="aspectFill"></image><text class="tm-name data-v-1e67a536">{{m.b}}</text><text class="{{['tm-fit-tag', 'data-v-1e67a536', m.d]}}">{{m.c}}</text></view></view></view><view wx:else class="team-members-empty data-v-1e67a536"><text class="tm-empty-text data-v-1e67a536">暂无成员加入</text></view></view></view></view><view wx:if="{{f}}" class="card create-section data-v-1e67a536"><text class="section-title data-v-1e67a536">创建组队</text><text class="section-subtitle data-v-1e67a536">从匹配记录中选择一个生成组队码</text><view class="match-list data-v-1e67a536"><view wx:for="{{g}}" wx:for-item="item" wx:key="e" class="match-item data-v-1e67a536" bindtap="{{item.f}}"><view class="match-left data-v-1e67a536"><image class="match-avatar data-v-1e67a536" src="{{item.a}}" mode="aspectFill"></image><view class="match-info data-v-1e67a536"><text class="match-relation data-v-1e67a536">{{item.b}}</text><text class="match-partner data-v-1e67a536">和 {{item.c}}</text></view></view><text class="match-code-btn data-v-1e67a536">{{item.d}}</text></view></view></view></view><view wx:if="{{h}}" class="overlay data-v-1e67a536" bindtap="{{m}}"><view class="modal data-v-1e67a536" catchtap="{{l}}"><text class="modal-title data-v-1e67a536">组队码</text><text class="modal-desc data-v-1e67a536">将组队码发给好友测合拍</text><view class="modal-code data-v-1e67a536">{{i}}</view><view class="modal-actions data-v-1e67a536"><view class="modal-btn data-v-1e67a536" bindtap="{{j}}">复制组队码</view><view class="modal-btn secondary data-v-1e67a536" bindtap="{{k}}">关闭</view></view></view></view></view>