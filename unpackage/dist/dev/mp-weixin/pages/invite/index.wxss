.complete-page.data-v-e54fd6d8 {
  min-height: 100vh;
  background: #FFF8F4;
  display: flex;
  align-items: center;
  justify-content: center;
}
.complete-content.data-v-e54fd6d8 {
  text-align: center;
  padding: 40rpx;
  width: 100%;
}
.complete-icon.data-v-e54fd6d8 {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #06D6A0, #00B894);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
}
.complete-icon-text.data-v-e54fd6d8 {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}
.complete-title.data-v-e54fd6d8 {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A2E;
  display: block;
  margin-bottom: 12rpx;
}
.complete-desc.data-v-e54fd6d8 {
  font-size: 26rpx;
  color: #6B7280;
  display: block;
  margin-bottom: 40rpx;
  line-height: 1.6;
}
.personality-card.data-v-e54fd6d8 {
  width: 80%;
  margin: 0 auto 32rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #FFFFFF;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}
.pc-full.data-v-e54fd6d8 {
  width: 100%;
  display: block;
}
.invite-box.data-v-e54fd6d8 {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 0 auto 32rpx;
  width: 80%;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
}
.invite-label.data-v-e54fd6d8 {
  font-size: 24rpx;
  color: #8B8B9E;
  display: block;
  margin-bottom: 12rpx;
}
.invite-code.data-v-e54fd6d8 {
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 10rpx;
  color: #FF6B35;
  display: block;
  margin-bottom: 12rpx;
  font-family: monospace;
}
.invite-hint.data-v-e54fd6d8 {
  font-size: 22rpx;
  color: #8B8B9E;
  display: block;
  line-height: 1.5;
}
.complete-actions.data-v-e54fd6d8 {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 80%;
  margin: 0 auto;
}
.action-btn.data-v-e54fd6d8 {
  padding: 26rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}
.action-btn.primary.data-v-e54fd6d8 {
  background: linear-gradient(135deg, #FF6B35, #F72585);
  color: #FFFFFF;
}
.action-btn.secondary.data-v-e54fd6d8 {
  background: #FFFFFF;
  color: #6B7280;
  border: 1rpx solid #EFEBE6;
}