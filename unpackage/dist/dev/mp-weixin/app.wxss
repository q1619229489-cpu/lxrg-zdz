/* 颜色变量 */
/* 人格配色 */
/* 尺寸 */
page {
  background-color: #F8F6F4;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  color: #1A1A2E;
}
.card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #EFEBE6;
}
.card-sm {
  background: #FFFFFF;
  border-radius: 14rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #EFEBE6;
}
.btn-primary {
  width: 100%;
  padding: 28rpx 0;
  background: linear-gradient(135deg, #FF6B35, #F72585);
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}
.btn-primary:active {
  opacity: 0.85;
}
.btn-secondary {
  width: 100%;
  padding: 24rpx 0;
  background: #FFFFFF;
  color: #FF6B35;
  border: 2rpx solid #FF6B35;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}
.btn-text {
  padding: 20rpx 0;
  background: transparent;
  color: #6B7280;
  border: 1rpx solid #EFEBE6;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
}
.tag {
  display: inline-flex;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 600;
}
.page-container {
  padding: 0 24rpx 120rpx;
  min-height: 100vh;
}
.safe-top {
  padding-top: var(--status-bar-height);
}page{--status-bar-height:25px;--top-window-height:0px;--window-top:0px;--window-bottom:0px;--window-left:0px;--window-right:0px;--window-magin:0px}[data-c-h="true"]{display: none !important;}